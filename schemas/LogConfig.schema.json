{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "LogConfig",
	"type": "object",
	"properties": {
		"enabled": {
			"type": "boolean",
			"description": "Enable or disable logging system wide",
			"default": true
		},
		"dir": {
			"type": "string",
			"description": "Directory to store log files",
			"default": "logs/"
		},
		"rotation": {
			"type": "string",
			"enum": [
				"daily",
				"hourly",
				"size"
			],
			"description": "File rotation strategy",
			"default": "daily"
		},
		"maxSizeMb": {
			"type": "number",
			"description": "Max file size in megabytes before rotation (only for size strategy)",
			"default": 10
		},
		"logBodies": {
			"type": "boolean",
			"description": "Whether to log request and response bodies (can blow up storage)",
			"default": false
		}
	},
	"additionalProperties": true
}